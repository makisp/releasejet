{
  "name": "releasejet",
  "version": "0.2.0",
  "description": "Automated release notes generator for GitLab and GitHub",
  "type": "module",
  "bin": {
    "releasejet": "./dist/cli.js"
  },
  "files": [
    "dist",
    "ci",
    ".releasejet.example.yml"
  ],
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "test:watch": "vitest",
    "dev": "tsx src/cli/index.ts"
  },
  "dependencies": {
    "@gitbeaker/rest": "^41.3.0",
    "@inquirer/prompts": "^7.2.0",
    "@octokit/rest": "^22.0.1",
    "commander": "^13.1.0",
    "semver": "^7.7.1",
    "yaml": "^2.7.0"
  },
  "devDependencies": {
    "@types/node": "^25.5.2",
    "@types/semver": "^7.5.8",
    "tsup": "^8.4.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vitest": "^3.1.0"
  },
  "engines": {
    "node": ">=20"
  }
}
